[Unit]
Description=Portfolio FastAPI Service
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/portfolio/mydeployaztu
ExecStart=/home/ubuntu/portfolio/mydeployaztu/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always

[Install]
WantedBy=multi-user.target
